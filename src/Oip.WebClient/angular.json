{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "oip": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/oip",
      "sourceRoot": "projects/oip/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {},
          "configurations": {
            "production": {
              "target": "oip:esbuild:production"
            },
            "development": {
              "target": "oip:esbuild:development",
              "dev": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation:build",
          "options": {
            "target": "oip:serve-original:development",
            "rebuildDelay": 500,
            "dev": true,
            "cacheExternalArtifacts": false,
            "port": 0
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "oip:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/oip/src/test.ts",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/oip/tsconfig.spec.json",
            "karmaConfig": "projects/oip/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/oip/src/favicon.ico",
              "projects/oip/src/assets"
            ],
            "styles": [
              "projects/oip/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/**"
            ]
          },
          "configurations": {
            "strict": {
              "strict": true
            }
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/oip",
            "index": "projects/oip/src/index.html",
            "polyfills": [
              "zone.js",
              "es-module-shims"
            ],
            "tsConfig": "projects/oip/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/oip/src/assets",
              {
                "glob": "**/*",
                "input": "node_modules/oip-common/assets",
                "output": "/assets"
              }
            ],
            "styles": [
              "projects/oip/src/styles.scss"
            ],
            "scripts": [],
            "browser": "projects/oip/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/oip/src/environments/environment.ts",
                  "with": "projects/oip/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "oip:esbuild:production"
            },
            "development": {
              "buildTarget": "oip:esbuild:development",
              "proxyConfig": "proxy.conf.js"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "proxy.conf.js",
            "ssl": true,
            "sslCert": "../../.devcontainer/https/oip.pem",
            "sslKey": "../../.devcontainer/https/oip.key",
            "publicHost": "https://localhost:50002",
            "port": 50002

          }
        }
      }
    },
    "oip-rtds": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/oip-rtds",
      "sourceRoot": "projects/oip-rtds/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/oip-rtds",
            "index": "projects/oip-rtds/src/index.html",
            "main": "projects/oip-rtds/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/oip-rtds/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/oip-rtds/src/assets",
              {
                "glob": "**/*",
                "input": "./projects/oip-common/src/assets",
                "output": "/assets/"
              }
            ],
            "styles": [
              "projects/oip-rtds/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/oip-rtds/src/environments/environment.ts",
                  "with": "projects/oip-rtds/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "oip-rtds:build:production"
            },
            "development": {
              "buildTarget": "oip-rtds:build:development",
              "proxyConfig": "proxy.conf.js"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "publicHost": "https://localhost:50003",
            "port": 50003,
            "headers": {
              "Content-Security-Policy": "script-src 'self' 'unsafe-inline' blob: https://localhost:50001;style-src 'self' 'unsafe-inline';img-src 'self' data:;font-src 'self';frame-ancestors 'self' https://s-gbt-wsn-00010:8443;block-all-mixed-content",
              "Access-Control-Allow-Origin": "*",
              "Access-Control-Allow-Headers": "Origin, X-Requested-With, Content-Type, Accept"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "oip-rtds:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/oip-rtds/src/test.ts",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/oip-rtds/tsconfig.spec.json",
            "karmaConfig": "projects/oip-rtds/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/oip-rtds/src/favicon.ico",
              "projects/oip-rtds/src/assets"
            ],
            "styles": [
              "projects/oip-rtds/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
